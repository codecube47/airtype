# Server Configuration
PORT=3001
ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://admin:admin123@localhost:27017/airtype?authSource=admin
MONGODB_DB=airtype

# JWT Configuration
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters

# Google OAuth Configuration
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here
GOOGLE_REDIRECT_URL=http://localhost:3001/api/auth/google/callback

# Groq API Configuration
# Get from: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# Desktop App
DESKTOP_CALLBACK_URL=airtype://auth/callback

# Storage (Optional - for production)
# S3_BUCKET=airtype-audio
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
